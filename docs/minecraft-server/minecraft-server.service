[Unit]
Description=Minecraft Server
After=network.target

[Service]
Type=simple
User=carbon
WorkingDirectory=/opt/shared/minecraft/server
ExecStart=/usr/bin/java -Xmx4G -Xms1G -XX:SoftMaxHeapSize=3G -XX:+UnlockExperimentalVMOptions -XX:+UseZGC -jar server.jar nogui
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
